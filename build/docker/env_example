# Docker Compose environment overrides

# PostgreSQL service
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=retinal_db
DB_PORT=5432

# Flask application service
FLASK_PORT=8080
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password_example

# Processing service
PROCESSING_SERVICE_PORT=5000
AZURE_STORAGE_SAS_TOKEN=your-sas-token

# Shared logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
# Paths are relative to /app inside the container; ./logs is bind-mounted to
# build/docker/logs/ on the host so files survive container crashes.
# LOG_FILE=logs/flask.log        # for flask-app (default)
# LOG_FILE=logs/classifier.log   # for classifier-service (default)

# pgAdmin service
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050